# Database - UPDATE THESE VALUES WITH YOUR POSTGRESQL DETAILS
DATABASE_URL="postgresql://postgres:password@localhost:5432/kryros?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="15m"

# Frontend URL
FRONTEND_URL="http://localhost:3000"

# Payment Gateways (Add your real keys from Paystack/Flutterwave dashboard)
PAYSTACK_SECRET_KEY="sk_test_your_key_here"
PAYSTACK_PUBLIC_KEY="pk_test_your_key_here"
FLUTTERWAVE_SECRET_KEY="FLWSECK-your-key-here"
FLUTTERWAVE_PUBLIC_KEY="FLWPUBK-your-key-here"

# Redis (Optional - for caching)
REDIS_URL="redis://localhost:6379"

# Mail (Optional)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# App
NODE_ENV="development"
PORT=4000
